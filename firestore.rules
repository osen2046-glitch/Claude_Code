rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 個人資料（文章 / 標籤）：僅限本人讀寫 ──
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── 公告欄 ──
    match /bulletins/{bulletinId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.keys().hasAll(['title', 'content', 'category', 'authorId', 'authorName', 'createdAt']);
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
      allow update: if false;

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.keys().hasAll(['content', 'authorId', 'authorName', 'createdAt']);
        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }

    // ── 解夢記錄：僅限本人讀寫 ──
    match /dreams/{dreamId} {
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'dreamText', 'methods', 'results', 'createdAt']);
      allow update, delete: if false;
    }

    // ── 神諭符文記錄（runes）：僅限本人讀寫 ──
    match /runes/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // ── 神諭抽卡記錄：僅限本人讀寫 ──
    match /rune_draws/{drawId} {
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'runeName', 'runeSymbol', 'oriented', 'label', 'createdAt']);
      allow update, delete: if false;
    }
  }
}
